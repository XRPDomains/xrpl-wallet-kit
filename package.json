{
  "name": "xrpl-wallet-kit-workspace",
  "private": true,
  "version": "0.1.3",
  "description": "Framework-agnostic XRPL Wallet Adapter / Wallet Kit monorepo.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/adapters/*",
    "examples/*"
  ],
  "scripts": {
    "prepare": "husky",
    "build": "tsc -b && node scripts/fix-esm-extensions.mjs",
    "build:browser": "npm run build && npm --workspace @xrpl-wallet-kit/browser run build && npm run smoke:browser",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run build && node --import tsx --test tests/*.test.ts",
    "smoke:browser": "node tests/browser-bundle-smoke.mjs",
    "check:integrity": "node scripts/check-file-integrity.mjs",
    "check:unused": "knip --no-progress --reporter compact",
    "check:unused:report": "knip --no-progress --reporter compact --no-exit-code",
    "check:duplicates": "jscpd --config .jscpd.json packages examples tests",
    "check:duplicates:report": "jscpd --config .jscpd.json --exitCode 0 packages examples tests",
    "check:deps": "depcruise --config .dependency-cruiser.cjs packages examples tests",
    "check:quality": "npm run typecheck && npm run check:deps && npm run check:unused:report && npm run check:duplicates:report",
    "build:vanilla": "node scripts/build-vanilla.mjs",
    "dev:vanilla": "node scripts/serve-vanilla.mjs",
    "dev:react": "node scripts/serve-react.mjs",
    "dev:html-legacy": "npm --workspace @xrpl-wallet-kit/example-html-legacy-bundle run dev"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@vitejs/plugin-react": "^4.3.4",
    "@walletconnect/modal": "^2.7.0",
    "@walletconnect/sign-client": "^2.23.9",
    "@walletconnect/types": "^2.23.9",
    "@walletconnect/utils": "^2.23.9",
    "buffer": "^6.0.3",
    "dependency-cruiser": "^17.4.0",
    "husky": "^9.1.7",
    "jscpd": "^4.2.3",
    "knip": "^6.14.1",
    "tsx": "^4.22.3",
    "typescript": "^5.5.4",
    "vite": "^6.4.3",
    "xumm": "^1.8.0",
    "xumm-oauth2-pkce": "^2.8.7"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XRPDomains/xrpl-wallet-kit.git"
  },
  "homepage": "https://github.com/XRPDomains/xrpl-wallet-kit#readme",
  "bugs": {
    "url": "https://github.com/XRPDomains/xrpl-wallet-kit/issues"
  },
  "keywords": [
    "xrpl",
    "wallet",
    "wallet-adapter",
    "wallet-kit",
    "xrp-ledger",
    "web3"
  ]
}
