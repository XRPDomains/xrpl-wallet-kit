# XRPL Wallet Kit local preview configuration
#
# Copy this file to `.env.local` for local development.
# Do not commit real production keys or private credentials.

# WalletConnect Cloud project id.
# Required for WalletConnect default/list/group preview modes.
VITE_WALLETCONNECT_PROJECT_ID=

# Xaman OAuth2/API key.
# Required for Xaman connect/auth preview.
VITE_XAMAN_CLIENT_ID=

# Optional destination used by WalletConnect message auth proof.
# The adapter signs a Payment transaction with Amount=1 drop and submit=false.
# Keep this different from the connected account for wallets that reject self-payments.
VITE_WALLETCONNECT_SIGN_MESSAGE_DESTINATION=

# Optional preview app metadata shown in wallet connection prompts.
VITE_XRPL_WALLET_KIT_APP_NAME="XRPL Wallet Kit Preview"
VITE_XRPL_WALLET_KIT_APP_DESCRIPTION="XRPL wallet adapter integration preview"
VITE_XRPL_WALLET_KIT_APP_URL="http://127.0.0.1:5173"
