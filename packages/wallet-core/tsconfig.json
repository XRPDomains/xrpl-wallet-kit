{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": "../..",
    "paths": {
      "@xrpname/wallet-core": ["packages/wallet-core/src/index.ts"],
      "@xrpname/wallet-adapter-xaman": ["packages/wallet-adapters/wallet-adapter-xaman/src/index.ts"],
      "@xrpname/wallet-adapter-gemwallet": ["packages/wallet-adapters/wallet-adapter-gemwallet/src/index.ts"],
      "@xrpname/wallet-adapter-crossmark": ["packages/wallet-adapters/wallet-adapter-crossmark/src/index.ts"],
      "@xrpname/wallet-adapter-dropfi": ["packages/wallet-adapters/wallet-adapter-dropfi/src/index.ts"],
      "@xrpname/wallet-adapter-ledger": ["packages/wallet-adapters/wallet-adapter-ledger/src/index.ts"],
      "@xrpname/wallet-adapter-walletconnect": ["packages/wallet-adapters/wallet-adapter-walletconnect/src/index.ts"],
      "@xrpname/wallet-adapter-xrpl-snap": ["packages/wallet-adapters/wallet-adapter-xrpl-snap/src/index.ts"],
      "@xrpname/wallet-ui": ["packages/wallet-ui/src/index.ts"],
      "@xrpname/wallet-react": ["packages/wallet-react/src/index.tsx"]
    },
    "strict": true,
    "skipLibCheck": true,
    "composite": true
  },
  "include": ["src"]
}
