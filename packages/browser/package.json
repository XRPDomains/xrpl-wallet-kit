{
  "name": "@xrpl-wallet-kit/browser",
  "version": "0.1.4",
  "description": "Browser-ready XRPL Wallet Kit bundle for vanilla JavaScript and legacy HTML sites.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/xrpl-wallet-kit.iife.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/xrpl-wallet-kit.iife.js"
    },
    "./iife": "./dist/xrpl-wallet-kit.iife.js",
    "./iife.min": "./dist/xrpl-wallet-kit.iife.min.js",
    "./legacy-bridge": "./dist/xrpl-wallet-kit-legacy-bridge.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build --mode readable && vite build --mode minified && node -e \"require('node:fs').rmSync('tsconfig.tsbuildinfo',{force:true})\" && tsc -p tsconfig.json"
  },
  "dependencies": {
    "@xrpl-wallet-kit/client": "0.1.4",
    "buffer": "^6.0.3"
  },
  "devDependencies": {
    "vite": "^6.4.3",
    "typescript": "^5.5.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XRPDomains/xrpl-wallet-kit.git"
  },
  "homepage": "https://github.com/XRPDomains/xrpl-wallet-kit#readme",
  "bugs": {
    "url": "https://github.com/XRPDomains/xrpl-wallet-kit/issues"
  },
  "keywords": [
    "xrpl",
    "wallet",
    "wallet-adapter",
    "wallet-kit",
    "xrp-ledger",
    "web3"
  ]
}
