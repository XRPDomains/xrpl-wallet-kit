{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": "../..",
    "paths": {
      "@xrpl-wallet-kit/core": ["packages/core/src/index.ts"],
      "@xrpl-wallet-kit/adapter-xaman": ["packages/adapters/xaman/src/index.ts"],
      "@xrpl-wallet-kit/adapter-gemwallet": ["packages/adapters/gemwallet/src/index.ts"],
      "@xrpl-wallet-kit/adapter-crossmark": ["packages/adapters/crossmark/src/index.ts"],
      "@xrpl-wallet-kit/adapter-dropfi": ["packages/adapters/dropfi/src/index.ts"],
      "@xrpl-wallet-kit/adapter-ledger": ["packages/adapters/ledger/src/index.ts"],
      "@xrpl-wallet-kit/adapter-walletconnect": ["packages/adapters/walletconnect/src/index.ts"],
      "@xrpl-wallet-kit/adapter-xrpl-snap": ["packages/adapters/xrpl-snap/src/index.ts"],
      "@xrpl-wallet-kit/ui": ["packages/ui/src/index.ts"],
      "@xrpl-wallet-kit/react": ["packages/react/src/index.tsx"]
    },
    "strict": true,
    "skipLibCheck": true,
    "composite": true
  },
  "include": ["src"]
}
